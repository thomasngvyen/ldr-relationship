generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")

  coupleAsA Couple? @relation("UserA")
  coupleAsB Couple? @relation("UserB")
  moodMessages MoodMessage[] @relation("UserMoodMessages")
  dateIdeas DateIdea[] @relation("UserDateIdeas")
  dateIdeaVotes DateIdeaVote[] @relation("UserDateIdeaVotes")
  @@map("users")
}

model Couple {
  id         String   @id @default(cuid())
  inviteCode String   @unique @map("invite_code")
  userAId    String   @unique @map("user_a_id")
  userBId    String?  @unique @map("user_b_id")
  createdAt  DateTime @default(now()) @map("created_at")

  userA User  @relation("UserA", fields: [userAId], references: [id], map: "couples_user_a_fkey")
  userB User? @relation("UserB", fields: [userBId], references: [id], map: "couples_user_b_fkey")

  visits Visit[] @relation("CoupleVisits")
  dateIdeas DateIdea[] @relation("CoupleDateIdeas")

  @@map("couples")
}

model Visit {
  id         String   @id @default(cuid())
  start_date DateTime @map("start_date")
  end_date   DateTime @map("end_date")
  coupleId   String   @map("couple_id")
  couple     Couple   @relation("CoupleVisits", fields: [coupleId], references: [id], map: "visits_couple_fkey")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("visits")
}

enum Mood {
  HAPPY
  SAD
  ANGRY
  EXCITED
  CONFUSED
  BORED
  TIRED
  SICK
  STRESSED
  RELAXED
  HORNY
  SLEEPY
}

model MoodMessage {
  id String @id @default(cuid())
  mood Mood
  message String
  createdAt DateTime @default(now())
  userId String @map("user_id")
  user User @relation("UserMoodMessages", fields: [userId], references: [id])
  @@map("mood_messages")
}

model DateIdea {
  id          String           @id @default(cuid())
  title       String
  description String
  category    DateIdeaCategory
  status      DateIdeaStatus   @default(IDEA)
  coupleId    String           @map("couple_id")
  userId      String           @map("user_id") // creator
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  couple Couple         @relation("CoupleDateIdeas", fields: [coupleId], references: [id], map: "date_ideas_couple_fkey")
  user   User           @relation("UserDateIdeas", fields: [userId], references: [id], map: "date_ideas_user_fkey")
  votes  DateIdeaVote[] @relation("DateIdeaVotes")

  @@map("date_ideas")
}

enum DateIdeaCategory {
  OUTDOOR
  INDOOR
  ACTIVE
  CASUAL
  ROMANTIC
  ADVENTUROUS
  COZY
}

enum DateIdeaStatus {
  IDEA
  VOTED
  SELECTED
  COMPLETED
}

model DateIdeaVote {
  id         String   @id @default(cuid())
  dateIdeaId String   @map("date_idea_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  dateIdea DateIdea @relation("DateIdeaVotes", fields: [dateIdeaId], references: [id], map: "date_idea_votes_date_idea_fkey", onDelete: Cascade)
  user     User     @relation("UserDateIdeaVotes", fields: [userId], references: [id], map: "date_idea_votes_user_fkey")

  @@unique([dateIdeaId, userId])
  @@map("date_idea_votes")
}
